# WriterLM backend production environment.
# Do not put Google/Groq/Tavily/Firecrawl provider keys here.
# Users add provider keys in the web UI; the backend stores them encrypted.

# App-owned Neon Postgres database used for users, encrypted keys, configs,
# jobs, and generated-book metadata.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk backend auth.
CLERK_SECRET_KEY=sk_live_replace_with_clerk_secret_key
# Optional but recommended issuer pin:
# CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWT_VERIFY_TIME=1
CLERK_JWT_LEEWAY_SECONDS=300

# Stable encryption key for user provider keys.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=replace-with-fernet-key

# Your deployed Vercel frontend URL(s), comma-separated.
APP_CORS_ORIGINS=https://your-frontend.vercel.app

# Safe non-secret pipeline defaults. Users still bring provider API keys.
LLM_PROVIDER=google
PLANNER_GOOGLE_MODEL=gemini-2.5-flash-lite
RESEARCHER_GOOGLE_MODEL=gemini-2.5-flash-lite
NOTES_GOOGLE_MODEL=gemini-2.5-flash-lite
WRITER_GOOGLE_MODEL=gemma-3-27b-it
REVIEWER_GOOGLE_MODEL=gemini-2.5-flash-lite
PLANNER_GROQ_MODEL=openai/gpt-oss-120b
RESEARCHER_GROQ_MODEL=openai/gpt-oss-120b
NOTES_GROQ_MODEL=llama-3.3-70b-versatile
WRITER_GROQ_MODEL=llama-3.3-70b-versatile
REVIEWER_GROQ_MODEL=openai/gpt-oss-120b
WRITERLM_STRICT_PROVIDER_MODELS=1
LLM_HTTP_TRUST_ENV=0

# Runtime.
PORT=8000
WRITERLM_COMPILE_LATEX=1
WRITERLM_STRICT_LATEX_COMPILE=0
LATEX_ENGINE=pdflatex
