TAVILY_API_KEY=replace-with-tavily-key

# Choose the default text provider for every pipeline layer.
# Supported values: google, groq
LLM_PROVIDER=google

# Google AI Studio / Gemini API
GOOGLE_API_KEY=replace-with-google-ai-studio-key
# Also accepted: GEMINI_API_KEY, GOOGLE_AI_API_KEY, GOOGLE_AI_STUDIO_API_KEY

# Optional Google model overrides. Leave unset to use the code defaults:
# planner/researcher/notes/reviewer: gemini-2.5-flash-lite
# writer: gemma-3-27b-it
PLANNER_GOOGLE_MODEL=gemini-2.5-flash-lite
RESEARCHER_GOOGLE_MODEL=gemini-2.5-flash-lite
NOTES_GOOGLE_MODEL=gemini-2.5-flash-lite
WRITER_GOOGLE_MODEL=gemma-3-27b-it
REVIEWER_GOOGLE_MODEL=gemini-2.5-flash-lite

# Optional Groq model overrides. These are ignored while LLM_PROVIDER=google.
PLANNER_GROQ_MODEL=openai/gpt-oss-120b
RESEARCHER_GROQ_MODEL=openai/gpt-oss-120b
NOTES_GROQ_MODEL=llama-3.3-70b-versatile
WRITER_GROQ_MODEL=llama-3.3-70b-versatile
REVIEWER_GROQ_MODEL=qwen/qwen3-32b

# Backward-compatible generic model variables still work as fallbacks, but
# provider-specific names above are preferred because they avoid cross-provider
# mistakes such as sending a Groq/Qwen model name to Google AI Studio.
# GOOGLE_MODEL=gemini-2.5-flash-lite
# GROQ_MODEL=openai/gpt-oss-120b
# WRITER_LLM_MODEL=gemma-3-27b-it

# The Codex desktop sandbox may inject a closed local proxy. Keep this at 0
# unless your machine needs HTTP_PROXY/HTTPS_PROXY for Google/Groq calls.
LLM_HTTP_TRUST_ENV=0

# Groq remains supported. To switch back, set LLM_PROVIDER=groq and provide:
# GROQ_API_KEY=replace-with-groq-key

# Per-layer provider overrides also work:
# RESEARCHER_LLM_PROVIDER=google
# WRITER_LLM_PROVIDER=groq

# Strict provider/model guard is on by default. With LLM_PROVIDER=google, model
# names must look like Google AI Studio text models, for example gemini-*,
# gemma-*, or models/gemini-*. Keep this enabled for normal runs.
WRITERLM_STRICT_PROVIDER_MODELS=1

# LaTeX compilation. The pipeline writes outputs/book.tex, then tries to build
# outputs/latex_build/book.pdf with latexmk/pdflatex/xelatex/lualatex.
# Keep strict mode off unless you want the whole run to fail when no TeX
# compiler is installed.
WRITERLM_COMPILE_LATEX=1
WRITERLM_STRICT_LATEX_COMPILE=0
# LATEX_ENGINE=pdflatex
# LATEX_TIMEOUT_SECONDS=240
# LATEX_ENGINE_PASSES=2

# Offline/quota-safe fallback mode for rebuilding a book from an existing
# research bundle. Useful when Google free-tier request limits are hit.
# WRITERLM_DETERMINISTIC_NOTES=1
# WRITERLM_DETERMINISTIC_WRITER=1
# WRITERLM_DETERMINISTIC_REVIEWER=1
