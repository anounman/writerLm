# WriterLM deployment environment
# Production should keep provider keys out of this file. Users add Google/Groq/Tavily/Firecrawl keys in the web UI; they are encrypted in the app database.

# Clerk authentication. Create an application at https://dashboard.clerk.com.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_replace_with_clerk_secret_key
# Optional issuer pin, e.g. https://your-app.clerk.accounts.dev
# CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
# Keep enabled in production. Set to 0 only for local machines with a bad clock.
CLERK_JWT_VERIFY_TIME=1

# Application database. Use your app-owned Neon Postgres database in production.
# This stores users, encrypted provider keys, configs, jobs, and generated-book metadata.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to encrypt per-user API keys at rest. If omitted, the backend derives
# an encryption key from CLERK_SECRET_KEY. Setting this explicitly is recommended.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=replace-with-fernet-key

APP_CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:5174

# Pipeline defaults. These are safe non-secret defaults; users still bring their own provider keys.
LLM_PROVIDER=google
PLANNER_GOOGLE_MODEL=gemini-2.5-flash-lite
RESEARCHER_GOOGLE_MODEL=gemini-2.5-flash-lite
NOTES_GOOGLE_MODEL=gemini-2.5-flash-lite
WRITER_GOOGLE_MODEL=gemma-3-27b-it
REVIEWER_GOOGLE_MODEL=gemini-2.5-flash-lite
PLANNER_GROQ_MODEL=openai/gpt-oss-120b
RESEARCHER_GROQ_MODEL=openai/gpt-oss-120b
NOTES_GROQ_MODEL=llama-3.3-70b-versatile
WRITER_GROQ_MODEL=llama-3.3-70b-versatile
REVIEWER_GROQ_MODEL=openai/gpt-oss-120b
WRITERLM_STRICT_PROVIDER_MODELS=1

# LaTeX / runtime defaults
WRITERLM_COMPILE_LATEX=1
WRITERLM_STRICT_LATEX_COMPILE=0
LATEX_ENGINE=pdflatex
LLM_HTTP_TRUST_ENV=0
