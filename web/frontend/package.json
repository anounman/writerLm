{
  "name": "writerlm-frontend-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0"
  },
  "scripts": {
    "dev": "nodemon --watch apps/studio --watch packages/ui --ext ts,tsx,js,jsx,json --exec \"npm run dev --workspace=apps/studio\"",
    "build": "npm run build --workspace apps/studio"
  },
  "overrides": {
    "vite": {
      "rollup": "npm:@rollup/wasm-node@4.60.3"
    }
  }
}
